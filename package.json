{
  "name": "betterstack1",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm build && bash scripts/start-dev.sh",
    "dev:stop": "bash scripts/stop-dev.sh",
    "docker:build": "bash scripts/docker-build.sh",
    "docker:up": "pnpm docker:build && docker compose up -d",
    "docker:down": "docker compose down",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
